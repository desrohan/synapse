{
  "name": "synapse",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev"
  },
  "dependencies": {
    "@synapse/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@synapse/config": "workspace:*",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3",
    "vercel": "^53.3.2"
  },
  "overrides": {
    "@assistant-ui/core": "latest",
    "@assistant-ui/store": "latest",
    "@assistant-ui/tap": "latest",
    "assistant-stream": "latest"
  },
  "packageManager": "bun@1.3.14"
}
